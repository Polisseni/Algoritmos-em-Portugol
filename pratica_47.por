// Calcular a média de 3 números

algoritmo "Media_Tres_Numeros"

var
   n1, n2, n3, media: real

inicio

   escreva("Digite o primeiro número: ")
   leia(n1)

   escreva("Digite o segundo número: ")
   leia(n2)

   escreva("Digite o terceiro número: ")
   leia(n3)

   media <- (n1 + n2 + n3) / 3

   escreval("A média é: ", media)

fimalgoritmo