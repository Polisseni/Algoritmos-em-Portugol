// Tabuada completa de 1 até 10

algoritmo "Tabuada_Completa"

var
   i, j: inteiro

inicio

   para i de 1 ate 10 faca
      escreval("Tabuada do ", i)

      para j de 1 ate 10 faca
         escreval(i, " x ", j, " = ", i * j)
      fimpara

      escreval("-------------------")

   fimpara

fimalgoritmo